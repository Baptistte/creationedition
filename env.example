# Base de données Neon
# Cette variable est automatiquement configurée par Netlify
# Pour le développement local, récupérez l'URL depuis votre dashboard Netlify
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Secret JWT pour l'authentification
# Générez une clé sécurisée aléatoire (minimum 32 caractères)
# Exemple: openssl rand -base64 32
JWT_SECRET=votre-secret-jwt-tres-securise-changez-moi

# EmailJS (envoi d'email côté serveur - formulaire de contact)
# Récupérez ces valeurs sur https://dashboard.emailjs.com
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=votre-cle-publique-emailjs

